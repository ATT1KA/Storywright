{
  "schema_version": "2.0",
  "text_strategy": "canonical_display",
  "constraint_registry": {
    "version": "1.0.0",
    "source": "src/ontology/constraint_registry.json",
    "notes": "The items below are mirrored from the shared runtime registry. Edit the source file and re-sync, not this template, to avoid divergence.",
    "items": [
      { "id": "meta.title", "maxChars": 120, "maxLines": 2, "guideline": "Formal title; 1–2 lines max." },
      { "id": "meta.subtitle", "maxChars": 70, "maxLines": 2, "guideline": "Arc descriptor or thesis fragment." },
      { "id": "meta.core_statement", "maxChars": 360, "maxLines": 4, "guideline": "Constitutional argument paragraph." },
      { "id": "meta.narrative_argument", "maxChars": 360, "maxLines": 4, "guideline": "Explains protagonist compatibility gap." },
      { "id": "principle.definition", "maxChars": 55, "maxLines": 2, "guideline": "Two-line thesis for Layer Map cards." },
      { "id": "entity.name", "maxChars": 24, "maxLines": 1, "guideline": "Name must fit ArcTimeline row label." },
      { "id": "entity.role", "maxChars": 28, "maxLines": 1, "guideline": "Single-line institutional role." },
      { "id": "entity.psychology", "maxChars": 420, "maxLines": 6, "guideline": "Inspector overview body copy." },
      { "id": "act.title", "maxChars": 24, "maxLines": 1, "guideline": "Act label in timeline header." },
      { "id": "act.question", "maxChars": 90, "maxLines": 3, "guideline": "Act dramatic question paragraph." },
      { "id": "act.tone", "maxChars": 32, "maxLines": 1, "guideline": "Italicized tone tag." },
      { "id": "arc.beat.state", "maxChars": 26, "maxLines": 1, "guideline": "Bold heading inside beat cell." },
      { "id": "arc.beat.detail", "maxChars": 65, "maxLines": 2, "guideline": "Body copy inside beat cell." },
      { "id": "relationship.type", "maxChars": 22, "maxLines": 1, "guideline": "Label in relationship cards/popovers." },
      { "id": "relationship.dynamic", "maxChars": 45, "maxLines": 2, "guideline": "Italic dynamic description." },
      { "id": "expression.content", "maxChars": 280, "maxLines": 4, "guideline": "Dialogue or expression snippet." },
      { "id": "cosmology.mechanism", "maxChars": 300, "maxLines": 4, "guideline": "Technical-cosmological field. Precise, not purple." },
      { "id": "variable.origin", "maxChars": 360, "maxLines": 5, "guideline": "Variable childhood/crossing fields. Intimate, specific register." },
      { "id": "dissolution.rule", "maxChars": 200, "maxLines": 3, "guideline": "Ending cosmological logic. Maximum precision, minimum ambiguity." },
      { "id": "critic.philosophy", "maxChars": 360, "maxLines": 4, "guideline": "Critic framework. Rigorous enough to be compelling; structurally subordinate to meta_thesis." },
      { "id": "meta_fictional.rule", "maxChars": 200, "maxLines": 3, "guideline": "Player-reality boundary rules. Constitutional authority." }
    ]
  },

  "semantic_registry": {
    "version": "1.0.0",
    "source": "src/ontology/semantic_registry.json",
    "notes": "Contracts define the content type and expected form for each field. LLMs and human authors must adhere to these contracts; importer validation enforces them.",
    "priority_contracts": [
      "character.role",
      "character.function_in_narrative",
      "character.psychology",
      "theme.definition",
      "theme.manifestation",
      "faction.structural_role",
      "faction.character",
      "arc.act",
      "protagonist.core_trait",
      "protagonist.the_flaw",
      "protagonist.the_hunger",
      "protagonist.core_belief.statement",
      "relationship.dynamic",
      "relationship.dramatic_function",
      "set_piece.thematic_argument"
    ]
  },

  "authoring_companion": {
    "editing_rules": [
      "Always modify canonical text first; display text is derived and will be overwritten by tooling.",
      "If you duplicated this template outside the repo, copy the latest constraint registry table along with it.",
      "When trimming canonical content to satisfy UX limits, prefer rewriting rather than truncating meaning—then rerun validation."
    ],
    "validation": "Run `npm run validate:bible` to confirm constraint registry parity and dual-track completeness before sharing with collaborators or LLMs.",
    "metadata_tip": "Top-level schema_version controls parsers. meta.version is purely narrative revision history."
  },

  "dual_track_field_map": {
    "ontology.meta.title": "meta.title",
    "ontology.meta.subtitle": "meta.subtitle",
    "ontology.meta.coreStatement": "meta.core_statement",
    "ontology.meta.narrativeArgument": "meta.narrative_argument",
    "ontology.principles[].definition": "principle.definition",
    "ontology.entities[].name": "entity.name",
    "ontology.entities[].role": "entity.role",
    "ontology.entities[].psychology": "entity.psychology",
    "ontology.entities[].arc[].state": "arc.beat.state",
    "ontology.entities[].arc[].movement": "arc.beat.detail",
    "ontology.acts[].title": "act.title",
    "ontology.acts[].question": "act.question",
    "ontology.acts[].tone": "act.tone",
    "ontology.relationships[].type": "relationship.type",
    "ontology.relationships[].dynamic": "relationship.dynamic",
    "ontology.expressions[].content": "expression.content"
  },

  "tooling_contract": {
    "importer": {
      "description": "Pure function, no LLM calls. Always treat canonical text as source of truth.",
      "steps": [
        "Parse JSON. If field is string, wrap into { canonical, display } shape automatically.",
        "Lookup constraint via constraint_registry and regenerate display.text by clamping canonical text.",
        "Overwrite any provided display.text with regenerated values.",
        "Log truncations in meta.changelog (append \"import_truncations\" entry with field paths)."
      ]
    },
    "exporter": {
      "default_profile": "Emit canonical + display objects exactly as stored after regeneration.",
      "legacy_profile": "Flatten to canonical strings for downstream tools; warn that display strings will be recomputed on next import."
    },
    "state_mutations": {
      "helper": "updateTextField(path, newCanonical, constraintId)",
      "rule": "Reducers/UI must call helper whenever a canonical text changes so display text is recalculated immediately."
    },
    "metadata_precedence": {
      "schema_version": "Controls parser behavior and dual-track expectations.",
      "meta.version": "Tracks narrative revisions only; does not affect importer logic."
    }
  },

  "meta": {
    "document_id": "[STORY_ID]_STORY_BIBLE_v2",
    "title": {
      "canonical": "[STORY TITLE — definitive, constitutional phrasing]",
      "display": { "constraint": "meta.title", "text": "[STORY TITLE]" }
    },
    "subtitle": {
      "canonical": "[SUBTITLE — protagonist arc stated as trajectory]",
      "display": { "constraint": "meta.subtitle", "text": "[PROTAG ARC]" }
    },
    "created": "[YYYY-MM-DD]",
    "updated": "[YYYY-MM-DD]",
    "version": "2.0",
    "document_purpose": "Canonical story bible and ground truth reference for all narrative development.",
    "usage_instructions": {
      "for_ai_models": "Treat canonical fields as constitutional truth. When editing, write to canonical text; display text is auto-derived via constraints.",
      "hierarchy_of_authority": [
        "1. meta_thesis + thematic_engine",
        "2. protagonist_architecture",
        "3. character_definitions",
        "4. faction_definitions",
        "5. narrative_structure",
        "6. world_building",
        "7. tone_and_aesthetic"
      ],
      "drift_prevention": "Before committing output, confirm canonical text still proves the meta_thesis, then allow tooling to clamp displays."
    },
    "text_strategy": "display strings are deterministic clamps of canonical strings; do not attempt to hand-author display text unless instructed, because importer will overwrite it.",
    "changelog": {
      "v1.0": "Initial canonical story bible.",
      "v2.0": "Introduced canonical/display dual-track schema with constraint registry."
    }
  },

  "meta_thesis": {
    "_instructions": "The meta_thesis is the constitutional layer. Fill canonical text richly; display text keeps UI legible.",
    "core_statement": {
      "canonical": "[THE STORY'S CENTRAL ARGUMENT IN 2-4 SENTENCES.]",
      "display": { "constraint": "meta.core_statement", "text": "[Concise argument for UI surfaces]" }
    },
    "narrative_argument": {
      "canonical": "[HOW THE PROTAGONIST EMBODIES THE CORE STATEMENT.]",
      "display": { "constraint": "meta.narrative_argument", "text": "[Shortened articulation]" }
    },
    "structural_parallel": "[STRUCTURAL CONTRIBUTION FROM REAL-WORLD/LITERARY ANTECEDENT]",
    "audience_contract": "[EMOTIONAL CONTRACT WITH AUDIENCE]",
    "thematic_summary": "[OPTIONAL DISTILLATION]"
  },

  "thematic_engine": {
    "_instructions": "Primary themes are load-bearing walls. Follow semantic contracts theme.definition + theme.manifestation for content/register. Canonical text can exceed UX limits if the data never surfaces directly; otherwise use dual-track objects.",
    "primary_themes": [
      {
        "theme": "[THEME NAME]",
        "definition": "[ABSTRACT PRINCIPLE]",
        "manifestation": "[HOW IT APPEARS IN THIS STORY]"
      }
    ],
    "structural_truths": [
      "[AXIOMATIC STATEMENT 1]",
      "[AXIOMATIC STATEMENT 2]",
      "[AXIOMATIC STATEMENT 3]"
    ]
  },

  "protagonist_architecture": {
    "_instructions": "Second-highest authority after meta_thesis. Contracts: protagonist.core_trait, protagonist.the_flaw, protagonist.the_hunger, protagonist.core_belief.statement describe expected voice/register.",
    "name": {
      "canonical": "[FULL NAME]",
      "display": { "constraint": "entity.name", "text": "[Name fits Arc Timeline]" }
    },
    "title": {
      "canonical": "[PUBLIC TITLE OR ROLE]",
      "display": { "constraint": "entity.role", "text": "[Concise Title]" }
    },
    "profession": "[SPECIFIC PROFESSIONAL IDENTITY]",
    "key_possessions": "[SIGNATURE OBJECTS]",
    "archetype": "[ARCHETYPE LABEL]",
    "archetype_lineage": [
      "[CHARACTER 1 — contribution]",
      "[CHARACTER 2 — contribution]"
    ],
    "psychology": {
      "core_trait": "[DEFINING FACT]",
      "origin": "[FORMATIVE BACKGROUND]",
      "the_hunger": "[IRRATIONAL DRIVE]",
      "the_performance": "[PUBLIC MASK]",
      "the_flaw": "[STRUCTURAL DEFICIENCY]",
      "the_blind_spot": "[UNSEEN TRUTH]",
      "relationship_to_power": "[MEDIUM OF SELF-EXPRESSION]",
      "core_belief": {
        "statement": "[FIRST-PERSON JUSTIFICATION]",
        "why_it_works": "[REASON BELIEF IS COMPELLING]",
        "how_it_drives_action": "[PLOT CONSEQUENCE]",
        "how_opposition_registers": "[PROTAGONIST PERCEPTION OF PUSHBACK]",
        "why_opponents_feel_discomfort": "[MORAL FRICTION FOR OTHERS]"
      }
    },
    "arc_logic": {
      "act_one": "[PROTAGONIST STATE]",
      "act_two": "[STATE]",
      "act_three": "[STATE]",
      "act_four": "[STATE]",
      "act_five": "[STATE]"
    },
    "fate": "[STRUCTURAL OUTCOME]",
    "legacy": "[WHAT SURVIVES]",
    "arc_movements": [
      {
        "movement": 1,
        "title": "[MOVEMENT TITLE]",
        "acts": "[ACT RANGE]",
        "audience_experience": "[FEELING]",
        "key_dynamic": "[MECHANISM]",
        "relatability_engine": "[HUMAN EXPERIENCE]"
      }
    ]
  },

  "ontology_payload": {
    "_instructions": "This section mirrors the runtime data structure Storywright uses. Every text field shown in UX is dual-track.",
    "meta": {
    "title": {
      "canonical": "[TITLE]",
      "display": { "constraint": "meta.title", "text": "[TITLE]", "clamp_strategy_used": "label_extract" },
      "contract": null
