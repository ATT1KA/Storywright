    ],
    "entities": [
      {
        "id": "e_001",
        "type": "character",
        "name": {
          "canonical": "[CHARACTER NAME]",
          "display": { "constraint": "entity.name", "text": "[CHAR NAME]", "clamp_strategy_used": "label_extract" },
