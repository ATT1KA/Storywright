      "contract": null
    },
    "narrativeArgument": {
      "canonical": "[NARRATIVE ARGUMENT]",
      "display": { "constraint": "meta.narrative_argument", "text": "[SHORT ARG]", "clamp_strategy_used": "first_sentence" },
