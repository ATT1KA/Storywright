    "acts": [
      {
        "number": 1,
        "title": {
          "canonical": "[ACT TITLE]",
          "display": { "constraint": "act.title", "text": "[ACT TITLE]", "clamp_strategy_used": "label_extract" },
          "contract": "arc.act"
        },
        "question": {
          "canonical": "[CENTRAL QUESTION]",
          "display": { "constraint": "act.question", "text": "[SHORT QUESTION]", "clamp_strategy_used": "first_sentence" },
          "contract": "arc.act"
        },
        "tone": {
          "canonical": "[TONAL REGISTER]",
          "display": { "constraint": "act.tone", "text": "[Tone Short]", "clamp_strategy_used": "label_extract" },
          "contract": null
        }
      }
    ],
    "relationships": [
      {
        "id": "r_001",
        "source": "e_001",
        "target": "e_002",
        "type": {
          "canonical": "[RELATIONSHIP TYPE]",
          "display": { "constraint": "relationship.type", "text": "[Type Short]", "clamp_strategy_used": "label_extract" },
          "contract": null
        },
        "dynamic": {
          "canonical": "[DYNAMIC DETAIL]",
          "display": { "constraint": "relationship.dynamic", "text": "[Dynamic Short]", "clamp_strategy_used": "first_clause" },
          "contract": "relationship.dynamic"
        },
        "tension": 0.6
      }
    ],
    "expressions": [
      {
        "id": "x_001",
        "type": "dialogue",
        "content": {
          "canonical": "[FULL LINE OR DESCRIPTION]",
          "display": { "constraint": "expression.content", "text": "[Trimmed quote for UX]", "clamp_strategy_used": "first_sentence" },
          "contract": null
        },
        "character": "e_001",
        "portability": "linguistic",
        "redundancy": 2
      }
    ]
  },

